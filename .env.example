# Скопируйте в .env и подставьте свои значения.
# GigaChat (для ИИ-распределения обращений по категориям):
# Ключ авторизации — строка Base64(client_id:client_secret), см. инструкцию в GIGACHAT_KEYS.md
GIGACHAT_CREDENTIALS=

# Опционально: включить проверку SSL (по умолчанию выключена для работы в РФ)
# GIGACHAT_VERIFY_SSL_CERTS=false

# Яндекс Геокодер (для тепловой карты: нормализация адресов и координаты)
# Получить ключ: https://developer.tech.yandex.ru/
YANDEX_GEOCODER_API_KEY=
# При SSL-ошибках (UNEXPECTED_EOF_WHILE_READING и т.п.) отключить проверку сертификата:
# YANDEX_GEOCODER_VERIFY_SSL=false
